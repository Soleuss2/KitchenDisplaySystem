@model List<SelfOrderingSystemKiosk.Models.StockMovement>
@using System.Linq
@{
    ViewData["Title"] = "Stock history";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var r = ViewBag.Range as string ?? "7";
}

<div class="content">
    <div class="header" style="margin-bottom: 16px; display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: space-between;">
        <div>
            <p style="margin: 0; color: #666;">Sales (when kitchen marks order done), restocks (dashboard), new items, and manual inventory edits.</p>
        </div>
        <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
            <span style="font-size: 0.9rem;">Range:</span>
            <a asp-action="Index" asp-route-range="1" style="padding: 8px 14px; text-decoration: none; border-radius: 8px; background: @(r == "1" ? "#ff6b35" : "#eee"); color: @(r == "1" ? "#fff" : "#333"); font-weight: @(r == "1" ? "600" : "400");">24h</a>
            <a asp-action="Index" asp-route-range="7" style="padding: 8px 14px; text-decoration: none; border-radius: 8px; background: @(r == "7" ? "#ff6b35" : "#eee"); color: @(r == "7" ? "#fff" : "#333"); font-weight: @(r == "7" ? "600" : "400");">7d</a>
            <a asp-action="Index" asp-route-range="30" style="padding: 8px 14px; text-decoration: none; border-radius: 8px; background: @(r == "30" ? "#ff6b35" : "#eee"); color: @(r == "30" ? "#fff" : "#333"); font-weight: @(r == "30" ? "600" : "400");">30d</a>
            <a asp-action="Index" asp-route-range="90" style="padding: 8px 14px; text-decoration: none; border-radius: 8px; background: @(r == "90" ? "#ff6b35" : "#eee"); color: @(r == "90" ? "#fff" : "#333"); font-weight: @(r == "90" ? "600" : "400");">90d</a>
        </div>
    </div>

    <div class="table-container" style="overflow-x: auto;">
        <table>
            <thead>
                <tr>
                    <th>Time (local)</th>
                    <th>Item</th>
                    <th>Δ</th>
                    <th>Before</th>
                    <th>After</th>
                    <th>Reason</th>
                    <th>Reference</th>
                    <th>Note</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="8" style="text-align: center; padding: 24px; color: #666;">No movements in this range.</td></tr>
                }
                else
                {
                    foreach (var m in Model)
                    {
                        <tr>
                            <td>@m.TimestampUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <strong>@m.ItemName</strong>
                                @if (!string.IsNullOrEmpty(m.InventoryItemId))
                                {
                                    <span style="font-size: 0.75rem; color: #888;">@m.InventoryItemId</span>
                                }
                            </td>
                            <td style="font-weight: 600; color: @(m.QuantityDelta < 0 ? "#c0392b" : "#27ae60");">@(m.QuantityDelta > 0 ? "+" : "")@m.QuantityDelta</td>
                            <td>@m.StockBefore</td>
                            <td>@m.StockAfter</td>
                            <td>@m.Reason</td>
                            <td>
                                <span style="font-size: 0.85rem;">@m.ReferenceType</span>
                                @if (!string.IsNullOrEmpty(m.ReferenceId))
                                {
                                    <br /><code style="font-size: 0.75rem;">@m.ReferenceId</code>
                                }
                            </td>
                            <td style="font-size: 0.85rem;">@m.Note</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
